# ============================================================
# PAC Backend — Environment Configuration Template
# Copy to .env and fill in your values
# ============================================================

# Application
APP_NAME="PAC - PoliceIT Analytics Core"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# ── PostgreSQL ────────────────────────────────────────────
# Async driver (used by FastAPI / SQLAlchemy at runtime)
DATABASE_URL=postgresql+asyncpg://pac_user:pac_password@postgres:5432/pac_db

# Sync driver (used by Alembic for migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://pac_user:pac_password@postgres:5432/pac_db

# ── JWT Security ──────────────────────────────────────────
# IMPORTANT: Generate a strong key in production
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Neo4j Graph Database ──────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pac_neo4j_password_2024

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── ML Engine ─────────────────────────────────────────────
MLENGINE_URL=http://mlengine:5001

# ── Ollama (AI Investigation Assistant only) ──────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://frontend:3000"]
